# Copy this to your shell profile or a local untracked .env.play file.
# Do not commit real passwords or keystores.

export FIREWORKS_ADMOB_APP_ID="ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy"
export FIREWORKS_ADMOB_REWARDED_ANDROID_ID="ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy"
export FIREWORKS_ADMOB_PUBLISHER_ID="pub-xxxxxxxxxxxxxxxx"
export FIREWORKS_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxxxx"
export FIREWORKS_ADS_TESTING="false"
export FIREWORKS_ADS_NPA="false"

export FIREWORKS_RELEASE_STORE_FILE="$HOME/.fireworks-play/fireworks-upload.jks"
export FIREWORKS_RELEASE_STORE_PASSWORD="replace-me"
export FIREWORKS_RELEASE_KEY_ALIAS="fireworks-upload"
export FIREWORKS_RELEASE_KEY_PASSWORD="replace-me"

export FIREWORKS_VERSION_CODE="1"
export FIREWORKS_VERSION_NAME="1.0"
